# All settings below are optional when using the Obsidian plugin —
# the plugin passes these as environment variables automatically.
# This file is only needed for standalone (CLI) use without the plugin.

# Path to your Obsidian vault on the host
# PKM_VAULT_PATH=/mnt/c/Users/you/Documents/MyVault

# Writable folder inside the vault (default: claude-workspace)
# PKM_WRITE_DIR=claude-workspace

# ttyd port (default: 7681)
# TTYD_PORT=7681

# Bind address for ttyd (default: 127.0.0.1, set 0.0.0.0 for network access)
# TTYD_BIND=127.0.0.1

# ttyd authentication (leave empty for no auth)
# TTYD_USER=user
# TTYD_PASSWORD=

# Allowed private network hosts for firewall (comma-separated IPs/CIDRs)
# Example: NAS, local API server
# ALLOWED_PRIVATE_HOSTS=192.168.1.100,10.0.0.5

# Container resource limits
# CONTAINER_MEMORY=8G
# CONTAINER_CPUS=4
