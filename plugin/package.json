{
	"name": "obsidian-agent-sandbox",
	"version": "0.1.1",
	"description": "Obsidian plugin for managing a Docker-based Claude Code environment",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint src/ *.mjs *.ts *.mts test/",
		"lint:fix": "eslint src/ *.mjs *.ts *.mts test/ --fix",
		"format": "prettier --write src/ test/ *.ts *.mts *.mjs styles.css",
		"format:check": "prettier --check src/ test/ *.ts *.mts *.mjs styles.css",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:e2e": "wdio run ./wdio.conf.mts",
		"test:e2e:headless": "xvfb-run -a wdio run ./wdio.conf.mts",
		"check": "npm run lint && npm run format:check && tsc -noEmit -skipLibCheck && npm run test:coverage",
		"version": "node version-bump.mjs",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "artislismanis",
	"license": "MIT",
	"engines": {
		"node": ">=24"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/xterm": "^5.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.0.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"@vitest/coverage-v8": "^4.1.6",
		"@wdio/cli": "^9.27.0",
		"@wdio/globals": "^9.27.0",
		"@wdio/local-runner": "^9.27.0",
		"@wdio/mocha-framework": "^9.27.0",
		"@wdio/spec-reporter": "^9.27.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.28.0",
		"eslint": "^10.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"mocha": "^11.7.5",
		"obsidian": "^1.7.2",
		"obsidian-launcher": "^3.0.2",
		"prettier": "^3.8.1",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3",
		"typescript-eslint": "^8.57.2",
		"vitest": "^4.1.2",
		"wdio-obsidian-reporter": "^3.0.2",
		"wdio-obsidian-service": "^3.0.2"
	},
	"overrides": {
		"lodash": "^4.18.1",
		"serialize-javascript": "^7.0.5"
	},
	"lint-staged": {
		"src/**/*.ts": [
			"eslint --fix",
			"prettier --write"
		],
		"test/**/*.{ts,mts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{mjs,mts,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.css": [
			"prettier --write"
		]
	}
}
